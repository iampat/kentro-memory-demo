# Copy to .env and fill in real values. Never commit .env.
#
# Only SECRETS belong here. Non-secret defaults (model names, cache toggle,
# state dir, server bind) live in `kentro.toml` at the repo root.
#
# Provider is auto-detected per tier from the model name in `kentro.toml`:
#   "claude-*" → Anthropic (requires ANTHROPIC_API_KEY)
#   "gemini-*" → Google    (requires GOOGLE_API_KEY)

ANTHROPIC_API_KEY=sk-ant-replace-me
GOOGLE_API_KEY=
