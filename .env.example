# Copy to .env and fill in real values. Never commit .env.

# --- LLM providers ---
# Provider is auto-detected per tier from the model name prefix:
#   "claude-*" → Anthropic (requires ANTHROPIC_API_KEY)
#   "gemini-*" → Google    (requires GOOGLE_API_KEY)
# Set both keys if you want to mix providers across tiers (or switch later).

ANTHROPIC_API_KEY=sk-ant-replace-me
GOOGLE_API_KEY=

# --- LLM tier model selection (no dated suffixes — names track the latest stable) ---
KENTRO_LLM_FAST_MODEL=claude-haiku-4-5
KENTRO_LLM_SMART_MODEL=claude-sonnet-4-6

# --- LLM cache toggle ---
# 1 = cache hits short-circuit; misses go to the provider and get cached.
# 0 = bypass cache entirely (every call hits the provider; for perf measurement).
KENTRO_LLM_CACHE_ENABLED=1

# --- Server ---
KENTRO_HOST=127.0.0.1
KENTRO_PORT=8000

# Where SQLite + blobs + Witchcraft + the LLM cache live on disk.
KENTRO_STATE_DIR=./kentro_state
