# Copy to .env and fill in real values. Never commit .env.

# --- LLM providers ---
# Provider used for the "fast" tier (NL → RuleSet, SkillResolver evaluation)
# and the "smart" tier (ingestion / extraction). Pick whichever you have a key for.

# Google Gemini (default for both tiers per the handoff)
GOOGLE_API_KEY=fake-gemini-key-replace-me
KENTRO_LLM_FAST_MODEL=gemini-3.1-flash-lite
KENTRO_LLM_SMART_MODEL=gemini-3.1-pro

# Anthropic (tested fallback)
ANTHROPIC_API_KEY=fake-anthropic-key-replace-me

# Set to 1 to disable real LLM calls and replay from tests/fixtures/llm_responses.json
KENTRO_LLM_OFFLINE=0

# --- Server ---
KENTRO_BASE_URL=http://localhost:8000
KENTRO_HOST=0.0.0.0
KENTRO_PORT=8000

# Where SQLite + blobs + semantic index live on disk
KENTRO_STATE_DIR=./kentro_state

# --- Demo / tenancy (hosted demo only; ignored locally) ---
# Comma-separated list of demo tenant IDs to seed at server start
KENTRO_DEMO_TENANTS=demo-1,demo-2,demo-3,demo-4,demo-5
# Per-tenant API keys, comma-separated, same order as KENTRO_DEMO_TENANTS
KENTRO_DEMO_API_KEYS=fake-key-1,fake-key-2,fake-key-3,fake-key-4,fake-key-5
